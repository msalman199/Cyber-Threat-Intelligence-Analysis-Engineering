def extract_cert_fingerprints(df):
    """Extract certificate fingerprints and metadata"""
    cert_info = []
    
    for _, row in df.iterrows():
        if pd.notna(row.get('cert_chain_fuids')):
            cert_info.append({
                'timestamp': row.get('ts'),
                'server_name': row.get('server_name'),
