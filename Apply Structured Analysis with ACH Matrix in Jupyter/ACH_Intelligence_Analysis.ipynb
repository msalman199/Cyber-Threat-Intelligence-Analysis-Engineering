def generate_ach_report(ach_matrix, scores):
    """Generate comprehensive ACH analysis report"""
    
    report = []
    report.append("# Analysis of Competing Hypotheses (ACH) Report")
    report.append("=" * 60)
    report.append("")
    
    # Executive Summary
    report.append("## Executive Summary")
    top_hypothesis = scores.index[0]
    top_score = scores.iloc[0]
    report.append(f"**Most Likely Hypothesis:** {top_hypothesis}")
    report.append(f"**Confidence Score:** {top_score:.3f}")
    report.append("")
    
    # Detailed Rankings
    report.append("## Hypothesis Rankings")
    for i, (hypothesis, score) in enumerate(scores.items(), 1):
        confidence_level = "High" if score > 1.0 else "Medium" if score > 0 else "Low"
        report.append(f"{i}. **{hypothesis}**")
        report.append(f"   - Score: {score:.3f}")
        report.append(f"   - Confidence: {confidence_level}")
        report.append("")
    
    # Key Evidence Analysis
    report.append("## Key Evidence Analysis")
    for evidence in ach_matrix.evidence:
        weight = ach_matrix.weights[evidence]
        report.append(f"**{evidence}** (Weight: {weight})")
        
        # Find strongest support/contradiction
        evidence_row = ach_matrix.matrix.loc[evidence]
        max_support = evidence_row.max()
        min_support = evidence_row.min()
        
        if max_support > 0:
            supporting_hyp = evidence_row.idxmax()
            report.append(f"   - Strongest Support: {supporting_hyp} ({max_support:+d})")
        
        if min_support < 0:
            contradicting_hyp = evidence_row.idxmin()
            report.append(f"   - Strongest Contradiction: {contradicting_hyp} ({min_support:+d})")
        report.append("")
    
    # Analytical Insights
    report.append("## Analytical Insights")
    
    # Calculate diagnosticity
    diagnosticity = {}
    for evidence in ach_matrix.evidence:
        evidence_row = ach_matrix.matrix.loc[evidence]
        variance = evidence_row.var()
        diagnosticity[evidence] = variance
    
    most_diagnostic = max(diagnosticity, key=diagnosticity.get)
    least_diagnostic = min(diagnosticity, key=diagnosticity.get)
    
    report.append(f"**Most Diagnostic Evidence:** {most_diagnostic}")
    report.append(f"**Least Diagnostic Evidence:** {least_diagnostic}")
    report.append("")
    
    # Recommendations
    report.append("## Recommendations")
    report.append("1. **Primary Focus:** Investigate the highest-scoring hypothesis with additional evidence collection")
    report.append("2. **Alternative Scenarios:** Maintain awareness of secondary hypotheses for contingency planning")
    report.append("3. **Evidence Gaps:** Seek additional evidence for low-weight or missing data points")
    report.append("4. **Continuous Assessment:** Update matrix as new evidence becomes available")
    
    return "\n".join(report)

# Generate and display report
