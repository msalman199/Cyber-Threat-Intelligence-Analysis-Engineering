ef validate_ach_analysis(ach_matrix, scores):
    """Validate the quality and completeness of ACH analysis"""
    
    validation_results = {}
    
    # Check matrix completeness
    total_cells = len(ach_matrix.hypotheses) * len(ach_matrix.evidence)
    filled_cells = ach_matrix.matrix.count().sum()
    completeness = (filled_cells / total_cells) * 100
    validation_results['Matrix Completeness'] = f"{completeness:.1f}%"
    
    # Check evidence weight coverage
    weighted_evidence = ach_matrix.weights.count()
    weight_coverage = (weighted_evidence / len(ach_matrix.evidence)) * 100
    validation_results['Evidence Weight Coverage'] = f"{weight_coverage:.1f}%"
    
    # Check score distribution
    positive_scores = (scores > 0).sum()
    negative_scores = (scores < 0).sum()
    neutral_scores = (scores == 0).sum()
    
    validation_results['Positive Hypotheses'] = positive_scores
    validation_results['Negative Hypotheses'] = negative_scores
    validation_results['Neutral Hypotheses'] = neutral_scores
    
    # Check for potential biases
    avg_consistency = ach_matrix.matrix.mean().mean()
    validation_results['Average Consistency'] = f"{avg_consistency:.3f}"
    
    # Diagnostic power assessment
    evidence_variance = []
    for evidence in ach_matrix.evidence:
        row_variance = ach_matrix.matrix.loc[evidence].var()
        if not pd.isna(row_variance):
            evidence_variance.append(row_variance)
    
    avg_diagnosticity = np.mean(evidence_variance) if evidence_variance else 0
    validation_results['Average Diagnosticity'] = f"{avg_diagnosticity:.3f}"
    
    print("ACH Analysis Validation Results:")
    print("=" * 40)
    for metric, value in validation_results.items():
        print(f"{metric}: {value}")
    
    # Quality assessment
    quality_score = 0
    if completeness >= 90: quality_score += 25
    elif completeness >= 75: quality_score += 20
    elif completeness >= 50: quality_score += 15
    
    if weight_coverage >= 90: quality_score += 25
    elif weight_coverage >= 75: quality_score += 20
    
    if avg_diagnosticity > 1.0: quality_score += 25
    elif avg_diagnosticity > 0.5: quality_score += 15
    
    if abs(avg_consistency) < 0.5: quality_score += 25
    elif abs(avg_consistency) < 1.0: quality_score += 15
    
    print(f"\nOverall Analysis Quality Score: {quality_score}/100")
    
    if quality_score >= 80:
        print("✓ High-quality analysis with strong methodological rigor")
    elif quality_score >= 60:
        print("⚠ Adequate analysis with room for improvement")
    else:
        print("✗ Analysis requires significant improvement")

# Run validation
validate_ach_analysis(ach, scores)

