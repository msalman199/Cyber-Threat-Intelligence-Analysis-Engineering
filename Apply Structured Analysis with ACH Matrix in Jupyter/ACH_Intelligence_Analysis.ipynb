class ACHMatrix:
    def __init__(self, hypotheses, evidence):
        self.hypotheses = hypotheses
        self.evidence = evidence
        self.matrix = pd.DataFrame(index=evidence, columns=hypotheses)
        self.weights = pd.Series(index=evidence, dtype=float)
        self.scores = pd.Series(index=hypotheses, dtype=float)
    
    def set_evidence_weight(self, evidence_item, weight):
        """Set reliability weight for evidence (0.1 to 1.0)"""
        self.weights[evidence_item] = weight
    
    def set_consistency(self, evidence_item, hypothesis, value):
        """Set consistency: +2 (strongly supports), +1 (supports), 
        0 (neutral), -1 (contradicts), -2 (strongly contradicts)"""
        self.matrix.loc[evidence_item, hypothesis] = value
    
    def calculate_scores(self):
        """Calculate weighted scores for each hypothesis"""
        for hypothesis in self.hypotheses:
            weighted_sum = 0
            total_weight = 0
            for evidence_item in self.evidence:
                if pd.notna(self.matrix.loc[evidence_item, hypothesis]):
                    consistency = self.matrix.loc[evidence_item, hypothesis]
                    weight = self.weights[evidence_item]
                    weighted_sum += consistency * weight
                    total_weight += weight
            
            self.scores[hypothesis] = weighted_sum / total_weight if total_weight > 0 else 0
        
        return self.scores.sort_values(ascending=False)
    
    def display_matrix(self):
        """Display the complete ACH matrix"""
        display_df = self.matrix.copy()
        display_df['Evidence Weight'] = self.weights
        return display_df


